DATABASE_URL=postgresql://aicore:aicore@postgres:5432/aicore

QDRANT_URL=http://qdrant:6333
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

QDRANT_HNSW_M=32
QDRANT_HNSW_EF_CONSTRUCT=200
QDRANT_HNSW_EF=100
QDRANT_HNSW_FULL_SCAN_THRESHOLD=10000
QDRANT_DEFAULT_SEGMENT_NUMBER=8
QDRANT_MAX_SEGMENT_SIZE=1500000
QDRANT_INDEXING_THRESHOLD=600000
QDRANT_POI_COLLECTION=poi_data
QDRANT_ATTRIBUTE_COLLECTION=attribute_data

EMBEDDING_SERVICE_URL=embedding:50051
EMBEDDING_SERVICE_MODEL=bge-m3
EMBEDDING_SERVICE_TIMEOUT=30
EMBEDDING_SERVICE_RETRY_COUNT=3
EMBEDDING_SERVICE_TYPE=False
EMBEDDING_SIZE=1024
VECTOR_UPSERT_BATCH_SIZE=10
ATTRIBUTE_SEARCH_PREFETCH_LIMIT=50
ATTRIBUTE_SEARCH_RRF_THRESHOLD=0.5
TASCO_POI_TOP_K=10
TASCO_ATTRIBUTE_TOP_K=5

OPENAI_API_KEY=<tự điền key openai vào đây>

# LLM Gateway (LiteLLM) — đổi provider/model tại đây khi chuyển nhà cung cấp
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
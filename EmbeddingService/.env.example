# Embedding Service — copy to .env and fill in values
# All settings below have defaults in the service; only override when needed.

# HuggingFace token (optional — increases rate limit for model download)
# HF_TOKEN=hf_...

# Model path (default: /app/models/bge-m3)
# BGE_M3_MODEL_PATH=/app/models/bge-m3

# Device: cpu or cuda
# USE_CPU=true
# USE_FP16=false

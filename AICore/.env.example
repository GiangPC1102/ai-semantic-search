# Environment
ENV=dev

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
OPENAI_API_KEY=sk-...

# ── Search ───────────────────────────────────────────────────────────────────
SEARCH_COLLECTION_NAME=poi
SEARCH_DEFAULT_TOP_K=10

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ── Embedding service (gRPC) ─────────────────────────────────────────────────
EMBEDDING_SERVICE_URL=aicore-embedding:50051
EMBEDDING_SERVICE_MODEL=bge-m3
EMBEDDING_SIZE=1024
EMBEDDING_SERVICE_TIMEOUT=30
EMBEDDING_SERVICE_RETRY_COUNT=3
